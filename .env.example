# Flask Configuration
SECRET_KEY=your-secret-key-here-generate-with-python-c-import-secrets-print-secrets-token-hex-32
FLASK_ENV=production
DEBUG=False

# WARNING: NEVER set DEBUG=True in production! It exposes sensitive information.

# Database Configuration
DATABASE_PATH=database/mmuinsight.db

# Email Configuration (Required for email verification)
# For Gmail: smtp.gmail.com, port 587, TLS enabled
# Generate App Password: https://myaccount.google.com/apppasswords
# For Outlook/Office 365: smtp-mail.outlook.com, port 587, TLS enabled
MAIL_SERVER=smtp-mail.outlook.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your-email@mmu.edu.my
MAIL_PASSWORD=your-email-password
MAIL_DEFAULT_SENDER=your-email@mmu.edu.my

# Instructions:
# 1. Copy this file to .env
# 2. Generate a secure SECRET_KEY: python -c "import secrets; print(secrets.token_hex(32))"
# 3. Replace 'your-secret-key-here' with the generated key
# 4. Configure email settings (Gmail App Password recommended)
# 5. Never commit the .env file to version control
